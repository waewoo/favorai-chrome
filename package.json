{
  "name": "favorai-extension",
  "version": "1.4.0",
  "description": "AI-powered bookmark manager Chrome extension",
  "type": "module",
  "scripts": {
    "lint": "eslint src/ background.js popup.js popup-light.js scripts/ tests/ vitest.config.js playwright.config.js --ext .js,.mjs",
    "lint:fix": "eslint src/ background.js popup.js popup-light.js scripts/ tests/ vitest.config.js playwright.config.js --ext .js,.mjs --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "test:e2e": "playwright test",
    "package": "node scripts/package.js",
    "postinstall": "npx playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/vitest-runner": "^8.7.1",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-plugin-security": "^4.0.0",
    "vitest": "^1.6.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "vite": "^6.4.2"
  }
}
