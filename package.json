{
  "name": "favorai-extension",
  "version": "1.5.0",
  "description": "AI-powered bookmark manager Chrome extension",
  "type": "module",
  "scripts": {
    "lint": "eslint src/ extension/ scripts/ tests/ vitest.config.js playwright.config.js eslint.config.js",
    "lint:fix": "eslint src/ extension/ scripts/ tests/ vitest.config.js playwright.config.js eslint.config.js --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "test:e2e": "playwright test",
    "package": "node scripts/package.js",
    "prepare": "husky",
    "postinstall": "npx playwright install chromium"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vcian/project-inspector": "^0.3.3",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.1",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "qs": "^6.15.2",
    "vite": "^8.0.16"
  }
}
