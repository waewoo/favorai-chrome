# Chrome Web Store publish credentials
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# 1. Go to https://console.cloud.google.com
# 2. Create a project → Enable "Chrome Web Store API"
# 3. Credentials → Create OAuth 2.0 Client ID (Desktop app)
# 4. Copy client_id and client_secret below
WEBSTORE_CLIENT_ID=your-client-id.apps.googleusercontent.com
WEBSTORE_CLIENT_SECRET=your-client-secret

# 5. Run once to get the refresh token:
#    make get-refresh-token
# 6. Paste the refresh token here
WEBSTORE_REFRESH_TOKEN=your-refresh-token

# 7. Copy your extension ID from the Chrome Web Store dashboard URL:
#    https://chrome.google.com/webstore/detail/YOUR_EXTENSION_ID
WEBSTORE_EXTENSION_ID=your-extension-id
