{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./.codex/hooks/aidd-context/update_memory.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./.codex/hooks/aidd-refine/condense-stats.js"
          }
        ]
      }
    ]
  }
}
